{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "baseUrl": "."
  },
  "files": [
    "src/components/ui/carousel.tsx",
    "src/components/resume/TemplateGallery.tsx",
    "src/store/resumeStore.ts",
    "src/types/resume.ts",
    "src/lib/utils.ts"
  ]
}