{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/components/resume/HtmlTemplate1.tsx",
    "src/components/resume/HtmlTemplate2.tsx",
    "src/components/resume/HtmlTemplate3.tsx",
    "src/components/resume/HtmlTemplate4.tsx",
    "src/components/resume/HtmlTemplate5.tsx",
    "src/components/resume/HtmlTemplate6.tsx"
  ]
}